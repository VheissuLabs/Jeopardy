services:
    -
        class: VheissuLabs\PHPStanLaravelAttributes\UseFactoryGenericsIgnoreExtension
        tags:
            - phpstan.ignoreErrorExtension
    -
        class: VheissuLabs\PHPStanLaravelAttributes\UseFactoryReturnTypeExtension
        tags:
            - phpstan.broker.dynamicStaticMethodReturnTypeExtension
